# ── Database (NEVER commit — the server's DB is the real one) ──
# The live SQLite DB must stay on each machine. Committing it caused the
# server database to be overwritten ("reset") on every `git pull`.
*.db
*.sqlite
*.sqlite3
backend/instance/
instance/

# ── Python bytecode / caches ──
__pycache__/
*.py[cod]
*.pyo

# ── Virtual envs ──
.venv/
venv/
env/

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# ── Backups ──
*.bak
*.db.*.bak
